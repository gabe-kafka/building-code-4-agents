      }
    },
    {
      "id": "k2_equation",
      "type": "formula",
      "section": "26.8",
      "text": "K₂ = (1 - |x|/μLh)",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "expression": "K₂ = (1 - |x|/μLh)",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "k3_equation",
      "type": "formula",
      "section": "26.8",
      "text": "K₃ = e^(-γz/Lh)",
