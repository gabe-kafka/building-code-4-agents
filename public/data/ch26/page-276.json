        "qc_status": "pending"
      }
    },
    {
      "id": "footnote_b",
      "type": "body",
      "section": "26.8",
      "text": "ᵇFor H/Lh > 0.5, assume that H/Lh = 0.5 for evaluating K₁ and substitute 2H for Lh for evaluating K₂ and K₃.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "footnote_c",
      "type": "body",
      "section": "26.8",
      "text": "ᶜMultipliers are based on the assumption that wind approaches the hill or escarpment along the direction of maximum slope.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "footnote_d",
      "type": "body",
      "section": "26.8",
      "text": "ᵈMultipliers shall be used for any exposure.",
