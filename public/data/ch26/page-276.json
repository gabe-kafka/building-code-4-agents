    {
      "id": "notation_h",
      "type": "body",
      "section": "26.8",
      "text": "**H** = Height of hill or escarpment relative to the upwind terrain, ft (m);",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "notation_k1",
      "type": "body",
      "section": "26.8",
      "text": "**K₁** = Factor to account for shape of topographic feature and maximum speed-up effect;",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "notation_k2",
      "type": "body",
      "section": "26.8",
      "text": "**K₂** = Factor to account for reduction in speed-up with distance upwind or downwind of crest;",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "notation_k3",
      "type": "body",
      "section": "26.8",
      "text": "**K₃** = Factor to account for reduction in speed-up with height above local terrain;",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "notation_lh",
      "type": "body",
      "section": "26.8",
      "text": "**Lh** = Distance upwind of crest to where the difference in ground elevation is half the height of hill or escarpment, ft (m);",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "notation_x",
      "type": "body",
      "section": "26.8",
      "text": "**x** = Distance (upwind or downwind) from the crest to the site of the building or other structure, ft (m);",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
