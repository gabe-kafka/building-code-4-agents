    {
      "id": "footnote_a",
      "type": "body",
      "section": "26.8",
      "text": "ᵃFor values of H/Lh, x/Lh, and z/Lh other than those shown, linear interpolation is permitted.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
