    {
      "id": "kzt_equation",
      "type": "formula",
      "section": "26.8",
      "text": "Kzt = (1 + K₁K₂K₃)²",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "full",
      "expression": "Kzt = (1 + K₁K₂K₃)²",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "k1_determination",
      "type": "body",
      "section": "26.8",
      "text": "K₁ = Determined from table above",
      "cross_references": [],
      "bbox": {
