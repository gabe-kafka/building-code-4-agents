    {
      "id": "26.7.4.1_provision",
      "type": "provision",
      "section": "26.7.4.1",
      "text": "For each wind direction considered, wind loads for the design of the MWFRS of enclosed and partially enclosed buildings using the Directional Procedure of Chapter 27 shall be based on the exposures as defined in Section 26.7.3. Wind loads for the design of open buildings with monoslope, pitched, or troughed free roofs shall be based on the exposures, as defined in Section 26.7.3, resulting in the highest wind loads for any wind direction at the site.",
      "cross_references": [
        "Chapter 27",
        "Section 26.7.3"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.7.4.2_heading",
      "type": "body",
      "section": "26.7.4.2",
      "text": "26.7.4.2 Envelope Procedure (Chapter 28)",
      "cross_references": [
        "Chapter 28"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
