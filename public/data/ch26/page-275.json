      }
    },
    {
      "id": "26.7.4.2_provision",
      "type": "provision",
      "section": "26.7.4.2",
      "text": "Wind loads for the design of the MWFRS for all low-rise buildings designed using the Envelope Procedure of Chapter 28 shall be based on the exposure category resulting in the highest wind loads for any wind direction at the site.",
      "cross_references": [
        "Chapter 28"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
