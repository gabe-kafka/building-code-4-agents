    {
      "id": "26.7.3_exposure_c",
      "type": "definition",
      "section": "26.7.3",
      "text": "**Exposure C.** Exposure C shall apply for all cases where Exposure B or D does not apply.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.7.3_exposure_d",
      "type": "definition",
      "section": "26.7.3",
      "text": "**Exposure D.** Exposure D shall apply where the ground surface roughness, as defined by Surface Roughness D, prevails in the upwind direction for a distance greater than 5,000 ft (1,524 m) or 20 times the building or structure height, whichever is greater. Exposure D shall also apply where the ground surface roughness immediately upwind of the site is B or C, and the building or structure is within a distance of 600 ft (183 m) or 20 times the building or structure height, whichever is greater, from an Exposure D condition as defined in the previous sentence.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.7.3_transition_zone",
      "type": "provision",
      "section": "26.7.3",
      "text": "For a building or structure located in the transition zone between exposure categories, the category resulting in the largest wind forces shall be used.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.7.3_exception",
      "type": "exception",
      "section": "26.7.3",
      "text": "**EXCEPTION:** An intermediate exposure between the preceding categories is permitted in a transition zone, provided it is determined by a rational analysis method defined in the recognized literature.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
