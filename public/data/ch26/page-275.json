      }
    },
    {
      "id": "26.7.4.3_heading",
      "type": "body",
      "section": "26.7.4.3",
      "text": "26.7.4.3 Directional Procedure for Building Appurtenances and Other Structures (Chapter 29)",
      "cross_references": [
        "Chapter 29"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "heading": true,
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.7.4.3_provision",
      "type": "provision",
      "section": "26.7.4.3",
      "text": "Wind loads for the design of building appurtenances (such as rooftop structures and equipment) and other structures (such as solid freestanding walls and freestanding signs, chimneys, tanks, open signs, single-plane open frames, and trussed towers) as specified in Chapter 29 shall be based on the appropriate exposure for each wind direction considered.",
      "cross_references": [
        "Chapter 29"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
