    {
      "id": "ASCE7-22-26.11-body004",
      "type": "body",
      "section": "26.11",
      "text": "The mean hourly wind speed (in ft/s or m/s) at the equivalent structure height, z̄, is",
      "cross_references": [],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
