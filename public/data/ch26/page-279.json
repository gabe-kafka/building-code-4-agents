    {
      "id": "ASCE7-22-26.12.1-provision1-body",
      "type": "provision",
      "section": "26.12.1",
      "text": "For the purpose of determining internal pressure coefficients, buildings and other structures for which internal pressure coefficients (GCpi) apply shall be classified as enclosed, partially enclosed, partially open, or open, as defined in Section 2.3. If a building or other structure satisfies both the \"open\" and \"partially enclosed\" enclosure classification definitions, it shall be classified as a \"partially open\" building or other structure.",
      "cross_references": [],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.505,
        "y_end": 0.56
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-26.12.3.2-glazing",
      "type": "provision",
      "section": "26.12.3.2",
      "text": "Glazing and impact-protective systems in buildings and other structures classified as Risk Category IV in accordance with Section 1.5 shall comply with the \"enhanced protection\" requirements of Table 3 of ASTM E1996. Glazing and impact-protective systems in all other buildings covered by Section 26.12.3.1 shall comply with the \"basic protection\" requirements of Table 3 of ASTM E1996.",
      "cross_references": [
        "1.5",
        "ASTM E1996",
        "26.12.3.1"
      ],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.54,
        "y_end": 0.62
      },
      "column": "right",
