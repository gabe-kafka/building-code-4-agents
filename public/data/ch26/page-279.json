    {
      "id": "ASCE7-22-26.11-formula009",
      "type": "formula",
      "section": "26.11",
      "text": "\\bar{V}_{\\bar{z}} = \\bar{b}\\left(\\frac{\\bar{z}}{33}\\right)^{\\bar{\\alpha}}\\frac{88}{60}V",
      "cross_references": [
        "26.11-1",
        "26.11.4"
      ],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.36,
        "y_end": 0.39
      },
      "column": "left",
      "expression": "\\bar{V}_{\\bar{z}} = \\bar{b}\\left(\\frac{\\bar{z}}{33}\\right)^{\\bar{\\alpha}}\\frac{88}{60}V",
      "parameters": [
        "\\bar{V}_{\\bar{z}} = mean hourly wind speed",
        "\\bar{b} = constant from Table 26.11-1",
        "\\bar{z} = equivalent height from Section 26.11.4",
        "\\bar{\\alpha} = constant from Table 26.11-1",
        "V = basic wind speed",
        "combined gust-effect factors and pressure coefficients (GC_{p}), (GC_{pi})",
        "and (GCpf) are given in figures and tables",
        "the gust-effect factor shall not be determined separately.",
        "\\bar{b} and \\bar{\\alpha} are constants listed in Table 26.11-1",
        "\\bar{z} is obtained from Section 26.11.4",
        "and V is the basic wind speed",
        "mi/h (m/s)."
      ],
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "left"
    },
