        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-26.12.3.1-list",
      "type": "body",
      "section": "26.12.3.1",
      "text": "1. Within 1 mi (1.6 km) of the mean high water line where an Exposure D condition exists upwind of the waterline and the basic wind speed is equal to or greater than 130 mi/h (58 m/s), or\n2. In areas where the basic wind speed is equal to or greater than 140 mi/h (63 m/s).",
      "cross_references": [],
      "bbox": {
