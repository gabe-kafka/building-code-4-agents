    {
      "id": "ASCE7-22-26.11.6-heading001-body",
      "type": "body",
      "section": "26.11.6",
      "text": "In lieu of the procedure defined in Sections 26.11.4 and 26.11.5, determination of the gust-effect factor by any rational analysis defined in the recognized literature is permitted.",
