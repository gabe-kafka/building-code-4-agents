    {
      "id": "ASCE7-22-26.10-F1",
      "type": "formula",
      "section": "26.10",
      "text": "qz = 0.00256KzKztKdV^2(lb/ft^2); V, mi/h",
      "cross_references": [],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.05,
        "y_end": 0.07
      },
      "column": "left",
      "expression": "q_z = 0.00256 K_z K_{zt} K_d V^2",
      "parameters": [
