    {
      "id": "26.11.2.1-alternative",
      "type": "provision",
      "section": "26.11.2.1",
      "text": "As an alternative to performing an analysis to determine n1, the approximate building natural frequency, na, shall be permitted to be calculated in accordance with Section 26.11.3 for structural steel, concrete, or masonry buildings meeting the following requirements:",
      "cross_references": [
        "26.11.3"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.11.2.1-requirements",
      "type": "body",
      "section": "26.11.2.1",
      "text": "1. The building height is less than or equal to 300 ft (91 m).\n2. The building height is less than four times its effective length, Leff.",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.11.2.1-effective-length",
      "type": "body",
      "section": "26.11.2.1",
      "text": "The effective length, Leff, in the direction under consideration shall be determined from the following equation:",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.11-formula-1",
      "type": "formula",
      "section": "26.11",
      "text": "Leff = (Σ(i=1 to n) hiLi) / (Σ(i=1 to n) hi)     (26.11-1)",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "left",
      "expression": "Leff = (∑hiLi) / (∑hi)",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
