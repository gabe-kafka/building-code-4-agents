      "expression": "n_a = \\frac{8.58}{h^{0.8}}",
      "parameters": [
        "n_a = approximate natural frequency in Hz",
        "h = height of structure in m"
      ],
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-26.11.3-B8",
      "type": "body",
      "section": "26.11.3",
      "text": "For concrete moment-resisting frame buildings,",
      "cross_references": [],
