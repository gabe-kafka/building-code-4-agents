        "qc_status": "pending"
      }
    },
    {
      "id": "26.11.3-frequency-determination",
      "type": "body",
      "section": "26.11.3",
      "text": "The approximate lower bound natural frequency (na), in Hz, of concrete or structural steel buildings meeting the conditions of Section 26.11.2.1 is permitted to be determined from one of the following equations.\nFor structural steel moment-resisting frame buildings,",
      "cross_references": [
        "26.11.2.1"
      ],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "right",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
    {
      "id": "26.11-formula-2",
      "type": "formula",
      "section": "26.11",
      "text": "na = 22.2/h⁰·⁸     (26.11-2)",
      "cross_references": [],
      "bbox": {
        "x_start": 0,
        "x_end": 1,
        "y_start": 0,
        "y_end": 1
      },
      "column": "right",
      "expression": "na = 22.2/h^0.8",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      }
    },
