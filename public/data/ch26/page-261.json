        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "right"
    },
    {
      "id": "ASCE7-22-26.1.2.1-provision1",
      "type": "provision",
      "section": "26.1.2.1",
      "text": "Wind loads for the MWFRS shall be determined using one of the following procedures:",
      "cross_references": [],
