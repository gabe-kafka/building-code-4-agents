      },
      "_source": "right"
    },
    {
      "id": "ASCE7-22-26.2-def6",
      "type": "definition",
      "section": "26.2",
      "text": "BUILDING, ENCLOSED: A building that has the total area of openings in each wall that receives positive external pressure less than or equal to 4 ft² (0.37 m²) or 1% of the area of that wall, whichever is smaller. This condition is expressed for each wall by the following equation:",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.4,
        "y_end": 0.44
      },
      "column": "right",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "right"
    },
    {
      "id": "ASCE7-22-26.2-formula1",
      "type": "formula",
      "section": "26.2",
      "text": "Aₒᵢ < 0.01Aᵢ or 4 ft² (0.37 m²), whichever is smaller,",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.44,
        "y_end": 0.46
      },
      "column": "right",
      "expression": "A_{oi} < 0.01A_i \\text{ or } 4 \\text{ ft}^2 (0.37 \\text{ m}^2), \\text{ whichever is smaller}",
      "parameters": [
        "A_{oi} = area of openings in wall i",
        "A_i = gross area of wall i",
        "Aₒᵢ and Aᵢ are as defined for Open Buildings."
      ],
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "right"
    },
