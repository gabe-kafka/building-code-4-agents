    {
      "id": "ASCE7-22-26.2-def3",
      "type": "definition",
      "section": "26.2",
      "text": "ATTACHED CANOPY: A horizontal (maximum slope of 2%) patio cover attached to the building wall at any height; it is different from an overhang, which is an extension of the roof surface.",
      "cross_references": [],
      "bbox": {
