    {
      "id": "ASCE7-22-26.2-definition4",
      "type": "definition",
      "section": "26.2",
      "text": "BASIC WIND SPEED, V: Three-second gust speed at 33 ft (10 m) above the ground in Exposure C (see Section 26.7.3) as determined in accordance with Section 26.5.1.",
      "cross_references": [
        "Section 26.7.3",
        "Section 26.5.1"
