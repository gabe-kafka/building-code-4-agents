      },
      "_source": "right"
    },
    {
      "id": "ASCE7-22-26.1.1-provision2",
      "type": "provision",
      "section": "26.1.1",
      "text": "Risk Category III and IV buildings and other structures, including the MWFRS and all C&C thereof, shall also be designed and constructed to resist tornado loads determined in accordance with Chapter 32, as applicable.",
      "cross_references": [
        "32"
      ],
      "bbox": {
