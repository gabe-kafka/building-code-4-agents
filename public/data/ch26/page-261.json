    {
      "id": "ASCE7-22-26.2-def5",
      "type": "definition",
      "section": "26.2",
      "text": "BUILDING, ELEVATED: A building supported on structural elements where wind can pass beneath the building.",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.38,
        "y_end": 0.4
      },
      "column": "right",
