    {
      "id": "ASCE7-22-26.1.2.1-body1",
      "type": "body",
      "section": "26.1.2.1",
      "text": "1. Directional Procedure for buildings of all heights as specified in Chapter 27 for buildings meeting the requirements specified therein;",
      "cross_references": [
        "27"
      ],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.5,
        "y_end": 0.53
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-26.1.2.1-body2",
      "type": "body",
      "section": "26.1.2.1",
      "text": "2. Envelope Procedure for low-rise buildings as specified in Chapter 28 for buildings meeting the requirements specified therein;",
      "cross_references": [
        "28"
      ],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.53,
        "y_end": 0.56
      },
      "column": "left",
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-26.2-formula1",
      "type": "formula",
      "section": "26.2",
      "text": "Ao < 0.01Ag or 4 ft² (0.37 m²), whichever is smaller,",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.53,
        "y_end": 0.56
      },
      "column": "right",
      "expression": "A_o < 0.01A_g \\text{ or } 4 \\text{ ft}^2 (0.37 \\text{ m}^2), \\text{ whichever is smaller}",
      "parameters": [
        "A_o = total area of openings in a wall that receives positive external pressure",
        "A_g = gross area of that wall",
        "Ao and Ag are as defined for Open Buildings."
      ],
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "right"
    },
