      },
      "_source": "right"
    },
    {
      "id": "ASCE7-22-27.3.4-F1",
      "type": "formula",
      "section": "27.3.4",
      "text": "p_p = q_p K_d (GC_{pm})",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.295,
        "y_end": 0.375
      },
      "column": "right",
      "expression": "p_p = q_p K_d (GC_{pm})",
      "parameters": [
        "p_p = Combined net pressure on the parapet caused by the combination of the net pressures from the front and back parapet surfaces in which plus (and minus) signs signify net pressure acting toward (and away from) the front (exterior) side of the parapet",
        "q_p = Velocity pressure evaluated at the top of the parapet",
        "K_d = Wind directionality factor (see Section 26.6)",
        "(GC_{pm}) = Combined net pressure coefficient, which is +1.5 for windward parapet or -1.0 for leeward parapet"
      ],
      "metadata": {
        "extracted_by": "vision-clone",
        "qc_status": "pending"
      },
      "_source": "right"
    },
    {
