    {
      "id": "ASCE7-22-27.3.4-H1-body",
      "type": "body",
      "section": "27.3.4",
      "text": "The design wind pressure for the effect of parapets on the MWFRS of rigid or flexible buildings in lbf/ft² (N/m²) shall be determined by Equation (27.3-3):",
      "cross_references": [],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.275,
        "y_end": 0.295
      },
