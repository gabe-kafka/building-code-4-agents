    {
      "id": "ASCE7-22-27.3.5-provision2",
      "type": "body",
      "section": "27.3.5",
      "text": "The eccentricity e for rigid buildings shall be measured from the geometric center of the building face and shall be considered for each principal axis (ex, ey). The eccentricity e for flexible buildings shall be determined from the following equation and shall be considered for each principal axis (ex, ey):",
      "cross_references": [],
      "bbox": {
