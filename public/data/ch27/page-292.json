        "x_end": 0.48,
        "y_start": 0.3,
        "y_end": 0.35
      },
      "column": "left",
      "expression": "e = \\frac{e_Q + 1.7 I_z \\sqrt{(q_Q Q_{eY})^2 + (g_R Re_R)^2}}{1 + 1.7 I_z \\sqrt{(q_Q Q)^2 + (g_R R)^2}}",
      "parameters": [
        "e_Q = Eccentricity e as determined for rigid buildings in Figure 27.3-8",
        "c_R = Distance between the elastic shear center and center of mass of each floor, and I_z, g_Q, Q, g_R, and R shall be as defined in Section 26.11"
      ],
      "metadata": {
        "extracted_by": "vision-clone",
