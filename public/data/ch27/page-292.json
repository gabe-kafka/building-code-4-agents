      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-27.3.5-body1",
      "type": "body",
      "section": "27.3.5",
      "text": "The sign of the eccentricity e shall be plus or minus, whichever causes the more severe load effect.",
