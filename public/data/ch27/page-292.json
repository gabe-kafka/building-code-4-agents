        "qc_status": "pending"
      },
      "_source": "left"
    },
    {
      "id": "ASCE7-22-27.3.5-body2",
      "type": "body",
      "section": "27.3.5",
      "text": "eQ = Eccentricity e as determined for rigid buildings in Figure 27.3-8; and\neR = Distance between the elastic shear center and center of mass of each floor, and Ixx, gQ, Q, gR, and R shall be as defined in Section 26.11.",
      "cross_references": [
        "Figure 27.3-8"
      ],
      "bbox": {
        "x_start": 0.52,
        "x_end": 0.94,
        "y_start": 0.08,
        "y_end": 0.12
