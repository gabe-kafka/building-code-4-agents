      "id": "ASCE7-22-27.3.5-heading1-body",
      "type": "body",
      "section": "27.3.5",
      "text": "The MWFRS of buildings of all heights, the wind loads of which have been determined under the provisions of this standard, shall be designed for the wind load cases as defined in Figure 27.3-8.",
      "cross_references": [
        "Figure 27.3-8"
      ],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.060000000000000005,
        "y_end": 0.15
      },
      "column": "left",
      "metadata": {
